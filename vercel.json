{
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    },
    "api/webhooks/stripe.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}

